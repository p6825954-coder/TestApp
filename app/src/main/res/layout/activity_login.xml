<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0E17"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Judul dengan animasi alpha di Java -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SECURE DEVICE"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"/>

    <!-- V5.0 merah tebal -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="V5.0"
        android:textColor="#FF1E5A"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="4dp"/>

    <!-- Subjudul -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="APLIKASI OPTIMALISASI JARAK JAUH"
        android:textColor="#9AA3B2"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginBottom="12dp"/>

    <!-- WebView untuk GIF dari URL -->
    <WebView
        android:id="@+id/gifWebView"
        android:layout_width="200dp"
        android:layout_height="150dp"
        android:layout_marginBottom="16dp"
        android:background="#00000000"/>

    <!-- Email -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EMAIL ANDA"
        android:textColor="#9AA3B2"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/emailInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="nama@gmail.com"
        android:textColor="#FFFFFF"
        android:background="#1A1A2E"
        android:padding="14dp"
        android:layout_marginBottom="12dp"
        android:inputType="textEmailAddress"/>

    <!-- Password -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="KATA SANDI"
        android:textColor="#9AA3B2"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/passwordInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="••••••••"
        android:textColor="#FFFFFF"
        android:background="#1A1A2E"
        android:padding="14dp"
        android:layout_marginBottom="32dp"
        android:inputType="textPassword"/>

    <!-- Tombol MASUK dengan animasi scale -->
    <Button
        android:id="@+id/loginBtn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="MASUK"
        android:textColor="#FFFFFF"
        android:background="#FF1E5A"
        android:textSize="18sp"
        android:textStyle="bold"/>

    <!-- Status -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FFC107"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginTop="16dp"/>
</LinearLayout>
