<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true"
    android:paddingTop="32dp"
    android:paddingBottom="48dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingRight="24dp">

        <!-- Logo & Nama Aplikasi -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SECURE DEVICE"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:gravity="center"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="V5.0"
            android:textColor="#FF1744"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="APK Remote Device Management"
            android:textColor="#9AA3B2"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Banner Ilustrasi (GIF) -->
        <WebView
            android:id="@+id/gifWebView"
            android:layout_width="220dp"
            android:layout_height="160dp"
            android:layout_marginBottom="24dp"
            android:background="#00000000"/>

        <!-- Form Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_glass"
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_marginBottom="20dp">

            <!-- Email Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textColor="#9AA3B2"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/emailInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="nama@gmail.com"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="@drawable/input_field"
                android:padding="16dp"
                android:drawableLeft="@android:drawable/ic_dialog_email"
                android:drawablePadding="12dp"
                android:layout_marginBottom="20dp"
                android:inputType="textEmailAddress"/>

            <!-- Password Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textColor="#9AA3B2"
                android:textSize="12sp"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/passwordInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="••••••••"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="@drawable/input_field"
                android:padding="16dp"
                android:drawableLeft="@android:drawable/ic_lock_idle_lock"
                android:drawablePadding="12dp"
                android:layout_marginBottom="28dp"
                android:inputType="textPassword"/>

            <!-- Tombol MASUK -->
            <Button
                android:id="@+id/loginBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="MASUK"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/btn_neon"/>

        </LinearLayout>

        <!-- Tombol Beli Akun -->
        <Button
            android:id="@+id/buyBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Beli Akun"
            android:textColor="#FF1744"
            android:textSize="14sp"
            android:background="@drawable/btn_outline"
            android:layout_marginTop="4dp"/>

        <!-- Status -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFC107"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="20dp"/>

    </LinearLayout>
</ScrollView>
