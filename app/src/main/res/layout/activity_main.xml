<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_admin">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#CC151515">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📱 Perangkat"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🟢 ONLINE"
            android:textColor="#00E676"
            android:textSize="12sp"
            android:background="@drawable/card_admin"
            android:padding="6dp 12dp"/>
    </LinearLayout>

    <!-- Filter Capsule -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp 16dp">
        <TextView
            android:text="Semua"
            android:background="@drawable/btn_admin"
            android:padding="8dp 16dp"
            android:textColor="#FFF"
            android:layout_marginEnd="8dp"/>
        <TextView
            android:text="Online"
            android:background="@drawable/btn_outline_admin"
            android:padding="8dp 16dp"
            android:textColor="#FFF"
            android:layout_marginEnd="8dp"/>
        <TextView
            android:text="Offline"
            android:background="@drawable/btn_outline_admin"
            android:padding="8dp 16dp"
            android:textColor="#9AA3B2"/>
    </LinearLayout>

    <!-- Daftar Perangkat -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:id="@+id/deviceContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp 16dp"/>
    </ScrollView>

    <!-- Bottom Nav -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/card_admin"
        android:gravity="center"
        android:orientation="horizontal">
        <TextView
            android:text="🏠 Beranda"
            android:textColor="#FF1744"
            android:layout_weight="1"
            android:gravity="center"/>
        <TextView
            android:text="🎛 Kontrol"
            android:textColor="#9AA3B2"
            android:layout_weight="1"
            android:gravity="center"/>
        <TextView
            android:text="👤 Profil"
            android:textColor="#9AA3B2"
            android:layout_weight="1"
            android:gravity="center"/>
    </LinearLayout>
</LinearLayout>
