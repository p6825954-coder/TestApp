<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0E17">

    <com.testapp.MatrixRainView
        android:id="@+id/matrixRain"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/controlContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Device Status Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="24dp">
                <TextView
                    android:id="@+id/deviceTitle"
                    android:text="Unknown"
                    android:textColor="#FF1E5A"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/profileInfo"
                    android:text="Loading..."
                    android:textColor="#9AA3B2"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <!-- Grid Kontrol 3 kolom -->
            <LinearLayout
                android:id="@+id/buttonGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <!-- Live Screen -->
            <TextView
                android:text="LIVE SCREEN"
                android:textColor="#2ED8FF"
                android:textStyle="bold"
                android:layout_marginTop="24dp"/>
            <ImageView
                android:id="@+id/liveScreenView"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:background="@drawable/glass_card"
                android:layout_marginTop="8dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">
                <Button
                    android:text="Start"
                    android:background="@drawable/btn_gradient"
                    android:textColor="#FFF"
                    android:layout_weight="1"/>
                <Button
                    android:text="Stop"
                    android:background="@drawable/btn_gradient"
                    android:textColor="#FFF"
                    android:layout_weight="1"/>
            </LinearLayout>

            <!-- Output Data -->
            <TextView
                android:id="@+id/dataOutput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#00E676"
                android:typeface="monospace"
                android:background="@drawable/glass_card"
                android:padding="12dp"
                android:layout_marginTop="16dp"/>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
