<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@drawable/bg_gradient"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center_vertical" android:layout_marginBottom="16dp">
        <TextView android:text="DEVICE MANAGER" android:textColor="#FFF"
            android:textSize="22sp" android:textStyle="bold" android:layout_weight="1"/>
        <TextView android:text="2" android:background="@drawable/red_button"
            android:paddingHorizontal="14dp" android:paddingVertical="6dp"
            android:textColor="#FFF" android:textSize="12sp"/>
    </LinearLayout>

    <!-- Filter Tabs -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="16dp">
        <TextView android:text="SEMUA" android:background="@drawable/red_button"
            android:paddingHorizontal="16dp" android:paddingVertical="6dp"
            android:textColor="#FFF" android:layout_marginEnd="8dp"/>
        <TextView android:text="ONLINE" android:background="@drawable/glass_card"
            android:paddingHorizontal="16dp" android:paddingVertical="6dp"
            android:textColor="#FFF" android:layout_marginEnd="8dp"/>
        <TextView android:text="OFFLINE" android:background="@drawable/glass_card"
            android:paddingHorizontal="16dp" android:paddingVertical="6dp"
            android:textColor="#9AA3B2" android:layout_marginEnd="8dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:id="@+id/deviceContainer"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

    <!-- Bottom Nav -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="@drawable/glass_card" android:gravity="center"
        android:orientation="horizontal">
        <TextView android:text="BERANDA" android:textColor="#2ED8FF"
            android:layout_weight="1" android:gravity="center"/>
        <TextView android:text="PROFIL" android:textColor="#9AA3B2"
            android:layout_weight="1" android:gravity="center"/>
    </LinearLayout>
</LinearLayout>
